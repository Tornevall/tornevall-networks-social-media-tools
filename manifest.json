{
  "name": "Tornevall Networks Social Media Tools",
  "description": "Tornevall Networks browser tools for social media workflows, server-side AI replies, and future admin/statistics integrations.",
  "version": "1.2.6",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/shared/platform-registry.js",
        "js/shared/facebook-admin-reporter.js",
        "js/shared/soundcloud-page-bridge.js",
        "js/platforms/facebook.js",
        "js/platforms/soundcloud.js",
        "js/platforms/x.js",
        "js/content-script.js"
      ],
      "css": [
        "css/styles.css"
      ]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "html/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "js/injected/network-monitor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
