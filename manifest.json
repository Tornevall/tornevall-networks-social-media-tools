{
  "name": "Tornevall Networks Social Media Tools",
  "short_name": "tornevall-networks-social-media-tools",
  "description": "Browser-wide AI assistant and social media toolkit. Text selection overlays, fact-checking, and AI replies on any website. Requires a personal Tornevall Networks Tools bearer token.",
  "version": "1.2.12",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/shared/platform-registry.js",
        "js/shared/facebook-admin-reporter.js",
        "js/shared/soundcloud-page-bridge.js",
        "js/platforms/facebook.js",
        "js/platforms/soundcloud.js",
        "js/platforms/x.js",
        "js/content-script.js"
      ],
      "css": [
        "css/styles.css"
      ]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "options_page": "html/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "icons/*.svg",
        "js/injected/network-monitor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
