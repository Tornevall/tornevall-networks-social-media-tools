{
  "name": "Tornevall Networks Social Media Tools",
  "description": "Tornevall Networks browser tools for social media workflows, server-side AI replies, and future admin/statistics integrations.",
  "version": "1.2.5",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/shared/platformRegistry.js",
        "js/shared/facebookAdminReporter.js",
        "js/platforms/facebook.js",
        "js/platforms/x.js",
        "js/contentScript.js"
      ],
      "css": [
        "css/styles.css"
      ]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "html/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "js/injected/networkMonitor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
