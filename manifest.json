{
  "name": "Tornevall Networks Social Media Tools",
  "short_name": "tornevall-networks-social-media-tools",
  "description": "Tornevall Networks browser tools for social media workflows, server-side AI replies, fact-checking, and admin/statistics integrations.",
  "version": "1.2.6",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.soundcloud.com/*"
      ],
      "js": [
        "js/injected/soundcloud-hook.mainworld.js"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/shared/platform-registry.js",
        "js/shared/facebook-admin-reporter.js",
        "js/shared/soundcloud-page-bridge.js",
        "js/platforms/facebook.js",
        "js/platforms/soundcloud.js",
        "js/platforms/x.js",
        "js/content-script.js"
      ],
      "css": [
        "css/styles.css"
      ]
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "icons/*.svg",
        "js/injected/network-monitor.js",
        "js/injected/soundcloud-hook.mainworld.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
